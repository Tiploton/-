#include <iostream>
#include <string>
using namespace std;

int main() {
	setlocale(LC_ALL, "Russian");
	char s;
	cin >> s;
	int num = 0;
	s = tolower(s);
	if (s == 'b')
		num = 1;
	else if (s == 'r')
		num = 2;
	else if (s == 'p')
		num = 3;
	else if (s == 'q')
		num = 4;
	else if (s == 'k')
		num = 5;
	else
		num = 6;
	switch (num) {
		case 1: cout << "Biship"; break;
		case 2: cout << "Rook"; break;
		case 3: cout << "Pawn"; break;
		case 4: cout << "Queen"; break;
		case 5: cout << "Knight,king"; break;
		case 6: cout << "Введите другую букву"; break;

	}
}
