#include <iostream>
using namespace std;

int main() {
    setlocale(LC_ALL, "russian");
    int x, y;
    int arr[3][5];
    int a[3][5] = {0};
    for (int i = 0; i < 3; ++i) {
        for (int j = 0; j < 5; ++j) {
            cin >> arr[i][j];
        }
    }
    cout << endl;
    for (int i = 0; i < 3; ++i) {
        for (int j = 0; j < 5; ++j) {
            if (arr[i][j] % 2 == 0 or a[0][j] != 0 or a[1][j] != 0 or a[2][j] != 0) {
                a[i][j] = arr[i][j];

            }
        }
    }
    for (int i = 2; i > -1; --i) {
        for (int j = 4; j > -1; --j) {
            if (arr[i][j] % 2 == 0 or a[0][j] != 0 or a[1][j] != 0 or a[2][j] != 0) {
                a[i][j] = arr[i][j];

            }
        }
    }
    cout << endl;
    for (int i = 0; i < 5; ++i) {
        int sum = 0;
        for (int j = 0; j < 3; ++j) {
            sum += a[j][i];
        }
        if (sum > 0) {
            cout <<"В стоблце под номером " << i+1 << " есть четные числа и сумма цифр в стобце равна: " << " " << sum << endl;
        }
    }
}
