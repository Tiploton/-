#include <iostream>
using namespace std;

int main()
{
	double x, y, z;
	cin >> x >> y >> z;
	if (x + y + z < 1) {
		if (x < y and x < z) {
			x = (x + z) / 2;
		}
		else if (y < x and y < z) {
			y = (x + z) / 2;
		}
		else{
			z = (x + y) / 2;
		}
	}
	else {
		if (x < y) {
			x = (x + z) / 2;
		}
		else {
			y = (x + z) / 2;
		}
	}
	cout << "x = " << x << endl << "y = " << y << endl << "z = " << z;
}
